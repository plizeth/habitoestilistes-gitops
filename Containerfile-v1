# ══════════════════════════════════════════════
# Containerfile — Hábito Estilistes Web
# Build con Podman usando imágenes UBI9 de Red Hat
#
# Build:   podman build -t habito-web .
# Run:     podman run -p 8080:8080 habito-web
# ══════════════════════════════════════════════

# ── Etapa 1: instalar dependencias
FROM registry.access.redhat.com/ubi9/nodejs-20:latest AS deps
WORKDIR /app

# Copia solo los manifiestos de dependencias primero
# (aprovecha el cache de capas de Podman/OCI)
COPY --chown=1001:0 package*.json ./
RUN npm ci --omit=dev --ignore-scripts

# ── Etapa 2: imagen de producción mínima (UBI9 Minimal)
FROM registry.access.redhat.com/ubi9/nodejs-20-minimal:latest

# Metadata OCI estándar
LABEL org.opencontainers.image.title="Habito Estilistes Web" \
      org.opencontainers.image.description="Web de la peluquería Hábito Estilistes — Castelldefels" \
      org.opencontainers.image.url="https://github.com/plizeth/habitoestilistes-gitops" \
      org.opencontainers.image.source="https://github.com/plizeth/habitoestilistes-gitops" \
      org.opencontainers.image.vendor="Hábito Estilistes" \
      org.opencontainers.image.licenses="Proprietary"

WORKDIR /app

# Copia node_modules desde la etapa deps
COPY --from=deps /app/node_modules ./node_modules

# Copia el código fuente
COPY server.js .
COPY --chown=1001:0 public ./public

# ── Seguridad: usuario no-root (OBLIGATORIO en OpenShift)
# OpenShift asigna UID aleatorio al pod; el directorio debe ser
# accesible por cualquier UID del grupo 0 (root group).
RUN chown -R 1001:0 /app && \
    chmod -R g=u /app

USER 1001

EXPOSE 8080

ENV PORT=8080 \
    NODE_ENV=production \
    NPM_CONFIG_UPDATE_NOTIFIER=false

# Healthcheck compatible con Podman
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8080/ || exit 1

CMD ["node", "server.js"]
